{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Roguecord",
  "version": "0.0.0",
  "identifier": "com.roguecord.client",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Roguecord",
        "width": 1280,
        "height": 800,
        "resizable": true,
        "decorations": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all"
  }
}
